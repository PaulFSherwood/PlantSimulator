/* =========================================================
   Process Flow full page
   ========================================================= */

.process-page {
    display: grid;
    gap: 1rem;
}

.process-tabs {
    display: flex;
    gap: 0.35rem;
    border-bottom: 1px solid var(--line);
    overflow-x: auto;
}

.process-tabs a {
    padding: 0.7rem 1rem;
    color: var(--muted);
    border: 1px solid transparent;
    border-bottom: 0;
    border-radius: 0.75rem 0.75rem 0 0;
    white-space: nowrap;
}

.process-tabs a.active {
    color: var(--text);
    background: #172840;
    border-color: var(--line);
}

.process-map-panel {
    min-height: 660px;
    padding: 1rem;
}

.process-legend {
    display: grid;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--muted);
}

.process-legend span {
    display: flex;
    align-items: center;
    gap: 0.45rem;
}

.process-legend i {
    width: 14px;
    height: 14px;
    display: inline-block;
    border-radius: 3px;
}

.legend-running { background: #22c55e; }
.legend-stopped { background: #eab308; }
.legend-fault { background: #ef4444; }
.legend-nocomms { background: #64748b; }

.scada-map {
    position: relative;
    height: 610px;
    min-width: 1180px;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--line);
    background:
        radial-gradient(circle at 15% 20%, rgba(34, 197, 94, 0.08), transparent 18rem),
        linear-gradient(180deg, #101923, #0c131b);
}

.scada-map-legend {
    position: absolute;
    right: 1rem;
    top: 1rem;
    z-index: 10;
    display: grid;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--muted);
}

.scada-map-legend span {
    display: flex;
    align-items: center;
    gap: 0.45rem;
}

.scada-map-legend i {
    width: 14px;
    height: 14px;
    display: inline-block;
    border-radius: 3px;
}

.process-tabs a.disabled {
    opacity: 0.45;
    cursor: not-allowed;
}

.scada-node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    min-width: 90px;
    text-align: center;
    z-index: 3;
}

.node-title {
    font-weight: 800;
    font-size: 0.82rem;
    color: var(--text);
}

.node-rate {
    margin-top: 0.2rem;
    color: var(--muted);
    font-size: 0.76rem;
}

.node-status {
    display: inline-block;
    margin-top: 0.3rem;
    padding: 0.18rem 0.45rem;
    border-radius: 0.3rem;
    font-size: 0.68rem;
    font-weight: 900;
}

.node-status.running {
    color: #bbf7d0;
    background: rgba(34, 197, 94, 0.24);
}

/* flow lines */

.flow-line {
    position: absolute;
    z-index: 1;
    border-radius: 999px;
}

.flow-line.running {
    background: #22c55e;
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.45);
}

.flow-line.warning {
    background: #eab308;
    box-shadow: 0 0 10px rgba(234, 179, 8, 0.45);
}

.flow-line.stopped {
    background: #64748b;
}

.line-receive-main {
    left: 160px;
    top: 255px;
    width: 105px;
    height: 6px;
}

.line-bin-header {
    left: 270px;
    top: 160px;
    width: 390px;
    height: 6px;
}

.line-bin1-drop {
    left: 270px;
    top: 160px;
    width: 6px;
    height: 155px;
}

.line-bin2-drop {
    left: 395px;
    top: 160px;
    width: 6px;
    height: 155px;
}

.line-bin3-drop {
    left: 520px;
    top: 160px;
    width: 6px;
    height: 155px;
}

.line-bin4-drop {
    left: 645px;
    top: 160px;
    width: 6px;
    height: 155px;
}

.line-auger-dryer {
    left: 455px;
    top: 350px;
    width: 6px;
    height: 90px;
}

.line-dryer-conveyor {
    left: 590px;
    top: 440px;
    width: 155px;
    height: 6px;
}

.line-conveyor-elevator {
    left: 820px;
    top: 215px;
    width: 6px;
    height: 215px;
}

.line-elevator-mixer {
    left: 820px;
    top: 430px;
    width: 6px;
    height: 35px;
}

.line-mixer-packaging {
    left: 885px;
    top: 465px;
    width: 115px;
    height: 6px;
}

.line-packaging-shipping {
    left: 1060px;
    top: 375px;
    width: 105px;
    height: 6px;
}

/* small equipment drawings */

.mini-hopper,
.mini-bin {
    width: 52px;
    height: 72px;
    margin: 0 auto 0.35rem;
    clip-path: polygon(50% 0, 100% 20%, 100% 68%, 62% 88%, 62% 100%, 38% 100%, 38% 88%, 0 68%, 0 20%);
    background:
        linear-gradient(90deg, #94a3b8, #e2e8f0 45%, #64748b);
    position: relative;
    overflow: hidden;
}

.mini-hopper::after,
.mini-bin::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: var(--fill, 55%);
    background:
        linear-gradient(135deg, rgba(255,255,255,0.14) 25%, transparent 25%) 0 0 / 10px 10px,
        linear-gradient(180deg, #d8aa37, #8b5e14);
}

.mini-dryer-box {
    position: relative;
    width: 86px;
    height: 42px;
    margin: 0 auto 0.35rem;
    border: 3px solid #64748b;
    border-radius: 8px 14px 14px 8px;
    background:
        repeating-linear-gradient(90deg, rgba(255,255,255,0.15) 0 6px, transparent 6px 14px),
        linear-gradient(180deg, #aab6c4, #566275);
}

.mini-dryer-box::before {
    content: "";
    position: absolute;
    left: -22px;
    top: -2px;
    width: 22px;
    height: 42px;
    border: 3px solid #64748b;
    border-radius: 5px 0 0 5px;
    background: #566275;
}

.mini-dryer-box::after {
    content: "";
    position: absolute;
    left: -15px;
    top: 18px;
    width: 12px;
    height: 18px;
    background: linear-gradient(180deg, #fbbf24, #ea580c);
    clip-path: polygon(50% 0, 100% 70%, 70% 100%, 30% 100%, 0 70%);
}

.mini-elevator {
    width: 44px;
    height: 116px;
    margin: 0 auto 0.35rem;
    border: 3px solid #64748b;
    border-radius: 999px 999px 8px 8px;
    background:
        repeating-linear-gradient(180deg, rgba(255,255,255,0.14) 0 8px, transparent 8px 16px),
        linear-gradient(90deg, #94a3b8, #475569);
}

/* Mill / Mixer */

.mini-mixer {
    position: relative;
    width: 58px;
    height: 112px;
    margin: 0 auto 0.35rem;
}

/* top dryer/mixer label box */
.mini-mixer::before {
    content: "Dryer";
    position: absolute;
    left: 0;
    top: 0;
    width: 58px;
    height: 32px;
    display: grid;
    place-items: center;
    border: 3px solid #64748b;
    border-radius: 4px;
    background: linear-gradient(180deg, #dbe4ee, #9aa8b8);
    color: #0f172a;
    font-size: 0.72rem;
    font-weight: 900;
}

/* vertical pipe */
.mini-mixer::after {
    content: "";
    position: absolute;
    left: 21px;
    top: 34px;
    width: 16px;
    height: 44px;
    border-left: 3px solid #64748b;
    border-right: 3px solid #64748b;
    background: linear-gradient(90deg, #94a3b8, #dbe4ee 50%, #64748b);
}

/* bottom motor/base */
.mixer-base {
    position: absolute;
    left: 4px;
    bottom: 0;
    width: 50px;
    height: 34px;
    border: 3px solid #64748b;
    border-radius: 4px;
    background: linear-gradient(180deg, #dbe4ee, #9aa8b8);
}

.mixer-base::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    border: 2px solid #334155;
}

.mini-packaging {
    width: 78px;
    height: 90px;
    margin: 0 auto 0.35rem;
    background:
        linear-gradient(#64748b, #64748b) 15px 55px / 60px 8px no-repeat,
        linear-gradient(#d6a535, #b7791f) 5px 40px / 22px 26px no-repeat,
        linear-gradient(#cbd5e1, #64748b) 44px 12px / 28px 42px no-repeat;
}

.auger-node::before,
.conveyor-node::before {
    content: "";
    display: block;
    width: 82px;
    height: 16px;
    margin: 0 auto 0.4rem;
    border: 2px solid #64748b;
    border-radius: 999px;
    background:
        repeating-linear-gradient(90deg, #334155 0 10px, #94a3b8 10px 18px);
}

.shipping-label {
    position: absolute;
    left: var(--x);
    top: var(--y);
    color: var(--text);
    font-weight: 800;
    z-index: 4;
}

@media (max-width: 1300px) {
    .process-map-panel {
        overflow-x: auto;
    }
}
